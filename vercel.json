{
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/monitor",
      "schedule": "*/5 * * * *"
    }
  ],
  "env": {
    "NODE_OPTIONS": "--no-warnings"
  },
  "build": {
    "env": {
      "NODE_OPTIONS": "--no-warnings"
    }
  }
}
