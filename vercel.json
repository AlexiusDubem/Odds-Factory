{
  "rewrites": [
    {
      "source": "/api/sportybet/:match*",
      "destination": "https://www.sportybet.com/api/ng/:match*"
    },
    {
      "source": "/api/sportmonks/:match*",
      "destination": "https://api.sportmonks.com/:match*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/monitor",
      "schedule": "*/5 * * * *"
    }
  ],
  "env": {
    "NODE_OPTIONS": "--no-warnings"
  },
  "build": {
    "env": {
      "NODE_OPTIONS": "--no-warnings"
    }
  }
}
